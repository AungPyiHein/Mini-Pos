@page "/"
@layout MainLayout

<div class="space-y-6">

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="kpi-card">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium text-muted">Total Revenue</span>
                <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">$48,295</p>
            <p class="text-xs text-emerald-600 font-medium mt-1">↑ 12.4% vs last month</p>
        </div>

        <div class="kpi-card">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium text-muted">Total Sales</span>
                <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" /></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">1,284</p>
            <p class="text-xs text-emerald-600 font-medium mt-1">↑ 8.1% vs last month</p>
        </div>

        <div class="kpi-card">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium text-muted">Customers</span>
                <div class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">342</p>
            <p class="text-xs text-emerald-600 font-medium mt-1">↑ 5.3% vs last month</p>
        </div>

        <div class="kpi-card">
            <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-medium text-muted">Products</span>
                <div class="w-8 h-8 rounded-lg bg-amber-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                </div>
            </div>
            <p class="text-2xl font-bold text-gray-900">86</p>
            <p class="text-xs text-red-500 font-medium mt-1">↓ 2 items out of stock</p>
        </div>
    </div>

    <!-- Chart + Top Products -->
    <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">

        <!-- Revenue chart placeholder -->
        <div class="card xl:col-span-2">
            <div class="card-header">
                <div>
                    <p class="text-sm font-semibold text-gray-900">Revenue Overview</p>
                    <p class="text-xs text-muted mt-0.5">Monthly performance</p>
                </div>
                <div class="flex gap-1">
                    <button class="px-2.5 py-1 text-xs rounded-md bg-accent text-white font-medium">Month</button>
                    <button class="px-2.5 py-1 text-xs rounded-md text-muted hover:bg-gray-100">Week</button>
                </div>
            </div>
            <div class="card-body">
                <!-- Chart placeholder with animated bars -->
                <div class="h-48 flex items-end gap-2 px-2">
                    @foreach (var (label, height, active) in ChartBars)
                    {
                        <div class="flex-1 flex flex-col items-center gap-1">
                            <div class="w-full rounded-t-md transition-all @(active ? "bg-accent" : "bg-gray-100")"
                                 style="height: @height%"></div>
                            <span class="text-xs text-muted">@label</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Top products -->
        <div class="card">
            <div class="card-header">
                <p class="text-sm font-semibold text-gray-900">Top Products</p>
                <span class="badge badge-info">This month</span>
            </div>
            <div class="divide-y divide-border/60">
                @foreach (var p in TopProducts)
                {
                    <div class="flex items-center gap-3 px-5 py-3">
                        <div class="w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center shrink-0 text-sm">
                            @p.Icon
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-medium text-gray-800 truncate">@p.Name</p>
                            <p class="text-xs text-muted">@p.Units units sold</p>
                        </div>
                        <p class="text-xs font-semibold text-gray-900">$@p.Revenue</p>
                    </div>
                }
            </div>
        </div>

    </div>

    <!-- Recent transactions -->
    <div class="card">
        <div class="card-header">
            <p class="text-sm font-semibold text-gray-900">Recent Transactions</p>
            <a href="sales" class="text-xs text-accent font-medium hover:underline">View all</a>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in RecentTransactions)
                    {
                        <tr>
                            <td class="font-medium text-accent">#@t.Id</td>
                            <td>@t.Customer</td>
                            <td>@t.Items item(s)</td>
                            <td class="text-muted">@t.Date</td>
                            <td class="font-semibold">$@t.Total</td>
                            <td><span class="badge @t.BadgeClass">@t.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    record ChartBar(string Label, int Height, bool Active = false);
    record ProductRow(string Icon, string Name, int Units, string Revenue);
    record Transaction(string Id, string Customer, int Items, string Date, string Total, string Status, string BadgeClass);

    List<(string label, int height, bool active)> ChartBars = new()
    {
        ("Jan", 45, false), ("Feb", 60, false), ("Mar", 38, false),
        ("Apr", 72, false), ("May", 55, false), ("Jun", 80, false),
        ("Jul", 65, false), ("Aug", 90, false), ("Sep", 70, false),
        ("Oct", 85, false), ("Nov", 95, false), ("Dec", 100, true),
    };

    List<ProductRow> TopProducts = new()
    {
        new("☕", "Espresso Shot", 412, "3,296"),
        new("🍕", "Margherita Pizza", 287, "4,592"),
        new("🧃", "Fresh Orange Juice", 203, "1,219"),
        new("🥗", "Caesar Salad", 178, "2,491"),
        new("🍰", "Chocolate Cake", 134, "1,876"),
    };

    List<Transaction> RecentTransactions = new()
    {
        new("10284", "Alice Johnson", 3, "25 Mar 2026", "87.50", "Completed", "badge badge-success"),
        new("10283", "Bob Smith", 1, "25 Mar 2026", "12.00", "Completed", "badge badge-success"),
        new("10282", "Carol White", 5, "24 Mar 2026", "214.00", "Completed", "badge badge-success"),
        new("10281", "David Lee", 2, "24 Mar 2026", "45.00", "Refunded", "badge badge-warning"),
        new("10280", "Eve Martinez", 4, "23 Mar 2026", "130.75", "Completed", "badge badge-success"),
    };
}
