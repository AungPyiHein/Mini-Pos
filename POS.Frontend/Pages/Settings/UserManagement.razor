@page "/settings/users"
@layout MainLayout

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">User Management</h2>
            <p class="page-subtitle">Manage staff access and roles</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" /></svg>
            Invite User
        </button>
    </div>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Role</th>
                        <th>Branch Access</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Users)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
                                        <span class="text-accent text-xs font-semibold">@u.Name[0]</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-medium text-gray-900">@u.Name</p>
                                        <p class="text-xs text-muted">@u.Email</p>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (u.Role == "Admin")
                                { <span class="badge bg-purple-100 text-purple-700">@u.Role</span> }
                                else if (u.Role == "Manager")
                                { <span class="badge badge-info">@u.Role</span> }
                                else
                                { <span class="badge bg-gray-100 text-gray-700">@u.Role</span> }
                            </td>
                            <td class="text-muted">@u.Branch</td>
                            <td>
                                @if (u.Active)
                                { <span class="badge badge-success">Active</span> }
                                else
                                { <span class="badge badge-warning">Inactive</span> }
                            </td>
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                    <button class="btn-ghost py-1 px-2 text-xs text-red-500">Revoke</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    record UserRow(string Name, string Email, string Role, string Branch, bool Active);

    List<UserRow> Users = new()
    {
        new("Admin User",   "admin@minipos.com",   "Admin",   "All Branches",   true),
        new("Sarah Smith",  "sarah@minipos.com",   "Manager", "Downtown Express", true),
        new("Mike Johnson", "mike@minipos.com",    "Cashier", "Downtown Express", true),
        new("Lisa Wong",    "lisa@minipos.com",    "Cashier", "Uptown Central",   true),
        new("Tom Davis",    "tom@minipos.com",     "Cashier", "Downtown Express", false),
    };
}
