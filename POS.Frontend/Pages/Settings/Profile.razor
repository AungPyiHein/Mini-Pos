@page "/settings/profile"
@layout MainLayout

<div class="max-w-3xl space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">My Profile</h2>
            <p class="page-subtitle">Manage your personal settings</p>
        </div>
        <button class="btn-primary">Save Changes</button>
    </div>

    <!-- Profile info -->
    <div class="card">
        <div class="card-header border-none pb-0">
            <p class="text-sm font-semibold text-gray-900">Personal Information</p>
        </div>
        <div class="card-body">
            <div class="flex items-center gap-5 border-b border-border pb-6 mb-6">
                <div class="w-20 h-20 rounded-full bg-accent text-white flex items-center justify-center text-3xl font-bold shadow-md">
                    AD
                </div>
                <div>
                    <button class="btn-secondary py-1.5 px-3 text-xs">Change Avatar</button>
                    <p class="text-xs text-muted mt-2">JPG, GIF or PNG. Max size of 800K</p>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Full Name</label>
                    <input type="text" class="form-input" value="Admin User" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Email Address</label>
                    <input type="email" class="form-input" value="admin@minipos.com" disabled />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Phone Number</label>
                    <input type="tel" class="form-input" value="+1 555-0000" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-gray-700 mb-1">Role</label>
                    <input type="text" class="form-input bg-gray-50 text-muted" value="Super Admin" disabled />
                </div>
            </div>
        </div>
    </div>

    <!-- Security -->
    <div class="card">
        <div class="card-header">
            <p class="text-sm font-semibold text-gray-900">Security</p>
        </div>
        <div class="card-body space-y-4 max-w-sm">
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Current Password</label>
                <input type="password" class="form-input" placeholder="••••••••" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">New Password</label>
                <input type="password" class="form-input" placeholder="••••••••" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-700 mb-1">Confirm New Password</label>
                <input type="password" class="form-input" placeholder="••••••••" />
            </div>
            <div class="pt-2">
                <button class="btn-secondary">Update Password</button>
            </div>
        </div>
    </div>

</div>

