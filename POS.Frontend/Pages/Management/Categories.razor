@page "/categories"
@layout MainLayout
@inject ICategoryService CategoryService
@inject IMerchantService MerchantService
@using POS.Frontend.Models.Categories
@using POS.Frontend.Models.Merchants
@using POS.Frontend.Services.Categories
@using POS.Frontend.Services.Merchants
@using POS.Shared.Models

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Categories</h2>
            <p class="page-subtitle">Organize your product categories</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Category
        </button>
    </div>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Products</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="relative">
                    @if (_isLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8">
                                <div class="flex flex-col items-center justify-center text-muted">
                                    <svg class="animate-spin h-8 w-8 text-primary mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <p>Loading categories...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-red-500">
                                <p>@_errorMessage</p>
                                <button class="btn-secondary mt-4" @onclick="LoadCategories">Try Again</button>
                            </td>
                        </tr>
                    }
                    else if (!CategoryList.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-muted">
                                <p>No categories found.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var c in CategoryList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-sm">📁</div>
                                        <span class="font-medium text-gray-800 dark:text-gray-200">@c.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted">@c.Description</td>
                                <td>@c.ProductCount products</td>
                                <td>
                                    <span class="badge badge-success">Active</span>
                                </td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => OpenEditModal(c)">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => DeleteCategory(c.Id)">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (showModal)
    {
        <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4">
            <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden animate-fade-in">
                <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
                    <h3 class="text-lg font-bold text-gray-800 dark:text-gray-200">@(isEditMode ? "Edit Category" : "Add New Category")</h3>
                    <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                    </button>
                </div>
                <div class="p-6 space-y-4">
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Category Name</label>
                        <input type="text" @bind="formModel.Name" class="form-input" placeholder="e.g. Beverages" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Description</label>
                        <textarea @bind="formModel.Description" class="form-input h-24" placeholder="Optional description..."></textarea>
                    </div>
                    @if (!isEditMode && MerchantList.Count > 1)
                    {
                        <div>
                            <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Merchant</label>
                            <select @bind="formModel.MerchantIdString" class="form-input">
                                @foreach (var m in MerchantList)
                                {
                                    <option value="@m.Id.ToString()">@m.Name</option>
                                }
                            </select>
                        </div>
                    }
                </div>
                <div class="px-6 py-4 bg-gray-50 dark:bg-surface border-t border-gray-100 flex justify-end gap-3">
                    <button @onclick="CloseModal" class="btn-secondary">Cancel</button>
                    <button @onclick="SaveCategory" class="btn-primary" disabled="@_isSaving">
                        @if (_isSaving)
                        {
                            <svg class="animate-spin h-4 w-4 mr-2" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                        }
                        @(isEditMode ? "Update Category" : "Create Category")
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@code {
    private List<CategoryResponseDto> CategoryList = new();
    private List<MerchantResponseDto> MerchantList = new();
    private bool _isLoading = true;
    private string? _errorMessage;
    private bool showModal = false;
    private bool isEditMode = false;
    private bool _isSaving = false;
    private CategoryFormModel formModel = new();

    private class CategoryFormModel
    {
        public Guid Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public Guid MerchantId { get; set; }

        public string MerchantIdString
        {
            get => MerchantId == Guid.Empty ? "" : MerchantId.ToString();
            set => MerchantId = Guid.TryParse(value, out var guid) ? guid : Guid.Empty;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadCategories(), LoadMerchants());
    }

    private async Task LoadMerchants()
    {
        var response = await MerchantService.GetAllMerchantsAsync();
        if (response?.Data != null)
        {
            MerchantList = response.Data.ToList();
        }
    }

    private async Task LoadCategories()
    {
        _isLoading = true;
        _errorMessage = null;

        var filter = new PaginationFilter { PageNumber = 1, PageSize = 100 };
        var response = await CategoryService.GetCategoriesAsync(filter);
        if (response?.IsSuccess == true && response.Data?.Data != null)
        {
            CategoryList = response.Data.Data.ToList();
        }
        else
        {
            _errorMessage = response?.Message ?? "Unknown error occurred";
        }
        _isLoading = false;
    }

    private void OpenAddModal()
    {
        isEditMode = false;
        formModel = new CategoryFormModel
        {
            MerchantId = MerchantList.FirstOrDefault()?.Id ?? Guid.Empty
        };
        showModal = true;
    }

    private void OpenEditModal(CategoryResponseDto c)
    {
        isEditMode = true;
        formModel = new CategoryFormModel
        {
            Id = c.Id,
            Name = c.Name,
            Description = c.Description
        };
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(formModel.Name)) return;

        _isSaving = true;
        _errorMessage = null;

        if (isEditMode)
        {
            var request = new UpdateCategoryRequest
            {
                id = formModel.Id,
                Name = formModel.Name,
                Description = formModel.Description
            };
            var result = await CategoryService.UpdateCategoryAsync(request);
            if (result.IsSuccess)
            {
                showModal = false;
                await LoadCategories();
            }
            else
            {
                _errorMessage = result.Message;
            }
        }
        else
        {
            var request = new CreateCategoryRequest
            {
                Name = formModel.Name,
                Description = formModel.Description,
                MerchantId = formModel.MerchantId
            };
            var result = await CategoryService.CreateCategoryAsync(request);
            if (result.IsSuccess)
            {
                showModal = false;
                await LoadCategories();
            }
            else
            {
                _errorMessage = result.Message;
            }
        }

        _isSaving = false;
    }

    private async Task DeleteCategory(Guid id)
    {
        var result = await CategoryService.DeleteCategoryAsync(id);
        if (result.IsSuccess)
        {
            await LoadCategories();
        }
        else
        {
            _errorMessage = result.Message;
        }
    }
}
