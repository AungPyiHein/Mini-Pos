@page "/products"
@layout MainLayout
@inject IProductService ProductService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Products</h2>
            <p class="page-subtitle">Manage your product catalog</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Product
        </button>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="flex gap-3 flex-wrap">
                <input type="text" placeholder="Search products…" class="form-input max-w-xs" />
                <select class="form-input w-40">
                    <option>All Categories</option>
                    <option>Beverages</option>
                    <option>Food</option>
                    <option>Bakery</option>
                    <option>Snacks</option>
                </select>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (isLoading)
                    {
                        <tr><td colspan="6" class="text-center py-4">Loading products...</td></tr>
                    }
                    else if (!ProductList.Any())
                    {
                        <tr><td colspan="6" class="text-center py-4 text-gray-500">No products found.</td></tr>
                    }
                    else
                    {
                        @foreach (var p in ProductList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <span class="text-lg">@GetCategoryIcon(p.CategoryName)</span>
                                        <span class="font-medium text-gray-800">@p.Name</span>
                                    </div>
                                </td>
                                <td><span class="badge badge-info">@p.CategoryName</span></td>
                                <td class="font-semibold">$@p.Price</td>
                                <td class="text-gray-400">-</td> <!-- Stock not supported yet -->
                                <td>
                                    <span class="badge badge-success">Available</span>
                                </td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    private List<ProductsResponseDto> ProductList = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        var filter = new POS.Shared.Models.PaginationFilter() { PageNumber = 1, PageSize = 50 };
        var response = await ProductService.GetProductsAsync(filter);
        if (response?.Data?.Data != null)
        {
            ProductList = response.Data.Data.ToList();
        }

        isLoading = false;
    }

    private string GetCategoryIcon(string category)
    {
        return category.ToLower() switch
        {
            "beverages" => "☕",
            "food" => "🍔",
            "bakery" => "🥐",
            "snacks" => "🍟",
            _ => "📦"
        };
    }
}
