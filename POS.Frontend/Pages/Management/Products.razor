@page "/products"
@layout MainLayout

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Products</h2>
            <p class="page-subtitle">Manage your product catalog</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Product
        </button>
    </div>

    <div class="card">
        <div class="card-header">
            <div class="flex gap-3 flex-wrap">
                <input type="text" placeholder="Search products…" class="form-input max-w-xs" />
                <select class="form-input w-40">
                    <option>All Categories</option>
                    <option>Beverages</option>
                    <option>Food</option>
                    <option>Bakery</option>
                    <option>Snacks</option>
                </select>
            </div>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in ProductList)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-2">
                                    <span class="text-lg">@p.Icon</span>
                                    <span class="font-medium text-gray-800">@p.Name</span>
                                </div>
                            </td>
                            <td><span class="badge badge-info">@p.Category</span></td>
                            <td class="font-semibold">$@p.Price</td>
                            <td>@p.Stock</td>
                            <td>
                                @if (p.Stock > 10)
                                { <span class="badge badge-success">In Stock</span> }
                                else if (p.Stock > 0)
                                { <span class="badge badge-warning">Low Stock</span> }
                                else
                                { <span class="badge badge-danger">Out of Stock</span> }
                            </td>
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                    <button class="btn-ghost py-1 px-2 text-xs text-red-500">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    record ProductRow(string Icon, string Name, string Category, string Price, int Stock);

    List<ProductRow> ProductList = new()
    {
        new("☕", "Espresso",         "Beverages", "3.50",  45),
        new("🥛", "Latte",            "Beverages", "4.50",  30),
        new("🧃", "Orange Juice",     "Beverages", "3.00",  60),
        new("🍵", "Green Tea",        "Beverages", "2.50",   8),
        new("🍕", "Margherita Pizza", "Food",      "16.00", 15),
        new("🥗", "Caesar Salad",     "Food",      "12.00", 20),
        new("🍔", "Cheeseburger",     "Food",      "11.50",  5),
        new("🥐", "Croissant",        "Bakery",    "3.50",  25),
        new("🍰", "Chocolate Cake",   "Bakery",    "5.50",  12),
        new("🧁", "Muffin",           "Bakery",    "2.75",   0),
        new("🍟", "Chips",            "Snacks",    "2.00",  80),
        new("🥜", "Nuts Mix",         "Snacks",    "4.00",   3),
    };
}
