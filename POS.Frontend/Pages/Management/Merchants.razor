@page "/merchants"
@layout MainLayout
@inject POS.Frontend.Services.Merchants.IMerchantService MerchantService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Merchants</h2>
            <p class="page-subtitle">Super Admin view of all businesses</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Register Merchant
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @ErrorMessage
        </div>
    }
    else
    {
        <div class="card">
            <div class="overflow-x-auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Merchant Name</th>
                            <th>Contact Email</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!MerchantList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-10 text-muted italic">No merchants found</td>
                            </tr>
                        }
                        @foreach (var m in MerchantList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-lg bg-gray-100 flex items-center justify-center shrink-0">
                                            <span class="text-gray-700 font-bold text-xs">@m.Name[0]</span>
                                        </div>
                                        <span class="font-medium text-gray-800">@m.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted">@m.ContactEmail</td>
                                <td>
                                    @if (m.isActive)
                                    { <span class="badge badge-success">Active</span> }
                                    else
                                    { <span class="badge badge-warning">Suspended</span> }
                                </td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs">Manage</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private List<MerchantResponseDto> MerchantList = new();
    private bool IsLoading = true;
    private string ErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadMerchants();
    }

    private async Task LoadMerchants()
    {
        IsLoading = true;
        ErrorMessage = "";
        try
        {
            var response = await MerchantService.GetAllMerchantsAsync();
            if (response.IsSuccess && response.Data != null)
            {
                MerchantList = response.Data.ToList();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
