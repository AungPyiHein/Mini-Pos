@page "/inventory"
@layout MainLayout
@using POS.Frontend.Models.Inventory
@using POS.Frontend.Models.Merchants
@using POS.Frontend.Models.Products
@using POS.Shared.Models
@inject POS.Frontend.Services.Inventory.IInventoryService InventoryService
@inject POS.Frontend.Services.Merchants.IBranchService BranchService
@inject POS.Frontend.Services.Products.IProductService ProductService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Inventory</h2>
            <p class="page-subtitle">Stock levels across all branches</p>
        </div>
        <button class="btn-primary" @onclick="() => ShowAdjustModal()">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Adjust Stock
        </button>
    </div>

    @if (IsLoadingBranches)
    {
        <div class="flex justify-center py-5">
            <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(BranchErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @BranchErrorMessage
        </div>
    }
    else
    {
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">
            <!-- Branch selector -->
            <div class="flex gap-2 flex-wrap">
                @foreach (var b in Branches)
                {
                    <button class="px-3 py-1.5 rounded-full text-xs font-medium transition-all @(SelectedBranch?.Id == b.Id ? "bg-accent text-white" : "bg-white dark:bg-surface border border-border text-muted hover:border-accent hover:text-accent")"
                            @onclick="() => SelectBranch(b)">
                        @b.Name
                    </button>
                }
            </div>

            <!-- Search -->
            <div class="flex items-center gap-2">
                <input type="text" placeholder="Search products…" class="form-input max-w-xs" 
                       @bind="searchTerm" @bind:event="oninput" @onkeyup="HandleSearch" />
                @if (IsSearching)
                {
                    <div class="w-4 h-4 border-2 border-accent/30 border-t-accent rounded-full animate-spin"></div>
                }
            </div>
        </div>
    }

    @if (SelectedBranch != null)
    {
        <div class="card">
            @if (IsLoadingInventory && !IsSearching)
            {
                <div class="flex justify-center py-20">
                    <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
                </div>
            }
            else if (!string.IsNullOrEmpty(InventoryErrorMessage))
            {
                <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm m-4">
                    @InventoryErrorMessage
                </div>
            }
            else
            {
                @if (LowStockCount > 0)
                {
                    <div class="flex items-center gap-3 px-4 py-3 bg-amber-50 border border-amber-200 rounded-xl text-sm m-4">
                        <svg class="w-4 h-4 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                        <span class="text-amber-800 font-medium">@LowStockCount items are running low or out of stock in @SelectedBranch.Name</span>
                    </div>
                }

                <div class="overflow-x-auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!InventoryItems.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-10 text-muted italic">No inventory found for this branch</td>
                                </tr>
                            }
                            @foreach (var item in InventoryItems)
                            {
                                <tr>
                                    <td>
                                        <div class="flex items-center gap-2">
                                            <span class="font-medium text-gray-800 dark:text-gray-200">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="font-semibold">@item.StockQuantity</td>
                                    <td>
                                        @if (item.StockQuantity == 0)
                                        { <span class="badge badge-danger">Out of Stock</span> }
                                        else if (item.StockQuantity <= 5)
                                        { <span class="badge badge-warning">Low Stock</span> }
                                        else
                                        { <span class="badge badge-success">OK</span> }
                                    </td>
                                    <td>
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => ShowAdjustModal(item)">Adjust</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                
                @if (!IsLoadingInventory && TotalRecords > 0)
                {
                    <div class="mt-6 border-t border-gray-100 dark:border-gray-800 pt-6">
                        <Pagination CurrentPage="CurrentPage" 
                                    TotalPages="TotalPages" 
                                    TotalRecords="TotalRecords" 
                                    PageSize="PageSize" 
                                    OnPageChanged="HandlePageChanged" />
                    </div>
                }
            }
        </div>
    }
    else if (!IsLoadingBranches && !Branches.Any())
    {
        <div class="text-center py-20 text-muted">
            No branches available. Please add a branch first.
        </div>
    }

</div>

@if (ShowModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-sm overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Adjust Stock</h3>
                <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                @if (AdjustmentRequest.ProductId == Guid.Empty)
                {
                    <div class="space-y-3">
                        <div class="p-3 bg-blue-50 text-blue-700 rounded-lg text-sm">
                            Select a product below to adjust its stock level.
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-muted mb-1 uppercase tracking-wider">Product</label>
                            <select class="form-input w-full" @onchange="HandleProductSelection">
                                <option value="">-- Choose Product --</option>
                                @foreach (var p in AllProducts)
                                {
                                    <option value="@p.Id.ToString()">@p.Name (@p.SKU)</option>
                                }
                            </select>
                        </div>
                    </div>
                }
                else
                {
                    <div>
                        <label class="block text-xs font-medium text-muted mb-1 uppercase tracking-wider">Product</label>
                        <div class="font-semibold text-gray-900 dark:text-gray-100">@SelectedProductName</div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-muted mb-1 uppercase tracking-wider">Current Stock</label>
                        <div class="text-gray-700 dark:text-gray-300">@CurrentStockQuantity</div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-muted mb-1 uppercase tracking-wider">Adjustment (+ / -)</label>
                        <input type="number" class="form-input w-full text-lg" @bind="AdjustmentRequest.QuantityChange" placeholder="e.g. 10 or -5" />
                        <p class="mt-1 text-xs text-muted italic">Positive adds stock, negative reduces it.</p>
                    </div>
                }
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface flex justify-end gap-3">
                <button @onclick="CloseModal" class="btn-ghost">Cancel</button>
                <button @onclick="HandleAdjustStock" class="btn-primary" disabled="@(IsSaving || AdjustmentRequest.ProductId == Guid.Empty)">
                    @if (IsSaving)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></div>
                    }
                    Save Adjustment
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BranchResponseDto> Branches = new();
    private BranchResponseDto? SelectedBranch;
    private List<InventoryResponseDto> InventoryItems = new();
    private List<ProductsResponseDto> AllProducts = new();
    
    private bool IsLoadingBranches = true;
    private bool IsLoadingInventory = false;
    private bool IsSaving = false;
    private bool ShowModal = false;
    private string BranchErrorMessage = "";
    private string InventoryErrorMessage = "";
    private string searchTerm = string.Empty;
    private bool IsSearching = false;
    private CancellationTokenSource? _searchCts;
    
    // Pagination
    private int CurrentPage = 1;
    private int TotalPages = 1;
    private int TotalRecords = 0;
    private int PageSize = 10;
    
    private UpdateStockRequest AdjustmentRequest = new();
    private string SelectedProductName = "";
    private int CurrentStockQuantity = 0;

    private int LowStockCount => InventoryItems.Count(i => i.StockQuantity <= 5);

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadBranches(), LoadAllProducts());
    }

    private async Task LoadAllProducts()
    {
        try
        {
            var response = await ProductService.GetProductsAsync(new PaginationFilter { PageSize = 1000 });
            if (response.IsSuccess && response.Data?.Data != null)
            {
                AllProducts = response.Data.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
        }
    }

    private async Task LoadBranches()
    {
        IsLoadingBranches = true;
        BranchErrorMessage = "";
        try
        {
            var response = await BranchService.GetAllBranchesAsync(new PaginationFilter { PageSize = 100 });
            if (response.IsSuccess && response.Data != null)
            {
                Branches = response.Data.Data.ToList();
                if (Branches.Any())
                {
                    await SelectBranch(Branches.First());
                }
            }
            else
            {
                BranchErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            BranchErrorMessage = "Error loading branches: " + ex.Message;
        }
        finally
        {
            IsLoadingBranches = false;
        }
    }

    private async Task SelectBranch(BranchResponseDto branch)
    {
        SelectedBranch = branch;
        CurrentPage = 1;
        await LoadInventory(branch.Id);
    }

    private async Task HandlePageChanged(int newPage)
    {
        CurrentPage = newPage;
        if (SelectedBranch != null)
        {
            await LoadInventory(SelectedBranch.Id);
        }
    }

    private async Task HandleSearch(KeyboardEventArgs e)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            CurrentPage = 1;
            if (SelectedBranch != null)
            {
                await LoadInventory(SelectedBranch.Id, isSearching: true);
            }
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private async Task LoadInventory(Guid branchId, bool isSearching = false)
    {
        if (!isSearching) IsLoadingInventory = true;
        IsSearching = isSearching;
        InventoryErrorMessage = "";
        try
        {
            var filter = new PaginationFilter 
            { 
                PageNumber = CurrentPage, 
                PageSize = PageSize,
                SearchTerm = searchTerm
            };
            var response = await InventoryService.GetBranchInventoryAsync(branchId, filter);
            if (response.IsSuccess && response.Data != null)
            {
                InventoryItems = response.Data.Data.ToList();
                TotalPages = response.Data.TotalPages;
                TotalRecords = response.Data.TotalRecords;
            }
            else
            {
                InventoryErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            InventoryErrorMessage = "Error loading inventory: " + ex.Message;
        }
        finally
        {
            IsLoadingInventory = false;
            IsSearching = false;
        }
    }

    private void ShowAdjustModal(InventoryResponseDto? item = null)
    {
        if (SelectedBranch == null) return;

        AdjustmentRequest = new UpdateStockRequest
        {
            BranchId = SelectedBranch.Id,
            ProductId = item?.ProductId ?? Guid.Empty,
            QuantityChange = 0
        };
        SelectedProductName = item?.ProductName ?? "";
        CurrentStockQuantity = item?.StockQuantity ?? 0;
        ShowModal = true;
    }

    private void HandleProductSelection(ChangeEventArgs e)
    {
        var productIdStr = e.Value?.ToString();
        if (Guid.TryParse(productIdStr, out var productId))
        {
            var product = AllProducts.FirstOrDefault(p => p.Id == productId);
            if (product != null)
            {
                AdjustmentRequest.ProductId = product.Id;
                SelectedProductName = product.Name;
                
                // Try to find current stock in the loaded list
                var existingItem = InventoryItems.FirstOrDefault(i => i.ProductId == productId);
                CurrentStockQuantity = existingItem?.StockQuantity ?? 0;
            }
        }
        else
        {
            AdjustmentRequest.ProductId = Guid.Empty;
            SelectedProductName = "";
            CurrentStockQuantity = 0;
        }
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private async Task HandleAdjustStock()
    {
        if (AdjustmentRequest.QuantityChange == 0)
        {
            ShowModal = false;
            return;
        }

        IsSaving = true;
        try
        {
            var response = await InventoryService.AdjustStockAsync(AdjustmentRequest);
            if (response.IsSuccess)
            {
                ShowModal = false;
                if (SelectedBranch != null)
                {
                    await LoadInventory(SelectedBranch.Id);
                }
            }
            else
            {
                // Optionally show error in modal
            }
        }
        finally
        {
            IsSaving = false;
        }
    }
}
