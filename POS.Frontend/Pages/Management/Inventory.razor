@page "/inventory"
@layout MainLayout
@using POS.Frontend.Models.Inventory
@using POS.Frontend.Models.Merchants
@inject POS.Frontend.Services.Inventory.IInventoryService InventoryService
@inject POS.Frontend.Services.Merchants.IBranchService BranchService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Inventory</h2>
            <p class="page-subtitle">Stock levels across all branches</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Adjust Stock
        </button>
    </div>

    @if (IsLoadingBranches)
    {
        <div class="flex justify-center py-5">
            <div class="animate-spin rounded-full h-6 w-6 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(BranchErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @BranchErrorMessage
        </div>
    }
    else
    {
        <!-- Branch selector -->
        <div class="flex gap-2 flex-wrap">
            @foreach (var b in Branches)
            {
                <button class="px-3 py-1.5 rounded-full text-xs font-medium transition-all @(SelectedBranch?.Id == b.Id ? "bg-accent text-white" : "bg-white border border-border text-muted hover:border-accent hover:text-accent")"
                        @onclick="() => SelectBranch(b)">
                    @b.Name
                </button>
            }
        </div>
    }

    @if (SelectedBranch != null)
    {
        @if (IsLoadingInventory)
        {
            <div class="flex justify-center py-20">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
            </div>
        }
        else if (!string.IsNullOrEmpty(InventoryErrorMessage))
        {
            <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
                @InventoryErrorMessage
            </div>
        }
        else
        {
            @if (LowStockCount > 0)
            {
                <div class="flex items-center gap-3 px-4 py-3 bg-amber-50 border border-amber-200 rounded-xl text-sm">
                    <svg class="w-4 h-4 text-amber-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                    <span class="text-amber-800 font-medium">@LowStockCount items are running low or out of stock in @SelectedBranch.Name</span>
                </div>
            }

            <div class="card">
                <div class="card-header">
                    <input type="text" placeholder="Search products…" class="form-input max-w-xs" />
                    <span class="text-xs text-muted">Branch: <strong>@SelectedBranch.Name</strong></span>
                </div>
                <div class="overflow-x-auto">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Quantity</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!InventoryItems.Any())
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-10 text-muted italic">No inventory found for this branch</td>
                                </tr>
                            }
                            @foreach (var item in InventoryItems)
                            {
                                <tr>
                                    <td>
                                        <div class="flex items-center gap-2">
                                            <span class="font-medium text-gray-800">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="font-semibold">@item.StockQuantity</td>
                                    <td>
                                        @if (item.StockQuantity == 0)
                                        { <span class="badge badge-danger">Out of Stock</span> }
                                        else if (item.StockQuantity <= 5)
                                        { <span class="badge badge-warning">Low Stock</span> }
                                        else
                                        { <span class="badge badge-success">OK</span> }
                                    </td>
                                    <td>
                                        <button class="btn-ghost py-1 px-2 text-xs">Adjust</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    }
    else if (!IsLoadingBranches && !Branches.Any())
    {
        <div class="text-center py-20 text-muted">
            No branches available. Please add a branch first.
        </div>
    }

</div>

@code {
    private List<BranchResponseDto> Branches = new();
    private BranchResponseDto? SelectedBranch;
    private List<InventoryResponseDto> InventoryItems = new();
    
    private bool IsLoadingBranches = true;
    private bool IsLoadingInventory = false;
    private string BranchErrorMessage = "";
    private string InventoryErrorMessage = "";
    private int LowStockCount => InventoryItems.Count(i => i.StockQuantity <= 5);

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
    }

    private async Task LoadBranches()
    {
        IsLoadingBranches = true;
        BranchErrorMessage = "";
        try
        {
            var response = await BranchService.GetAllBranchesAsync();
            if (response.IsSuccess && response.Data != null)
            {
                Branches = response.Data.ToList();
                if (Branches.Any())
                {
                    await SelectBranch(Branches.First());
                }
            }
            else
            {
                BranchErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            BranchErrorMessage = "Error loading branches: " + ex.Message;
        }
        finally
        {
            IsLoadingBranches = false;
        }
    }

    private async Task SelectBranch(BranchResponseDto branch)
    {
        SelectedBranch = branch;
        await LoadInventory(branch.Id);
    }

    private async Task LoadInventory(Guid branchId)
    {
        IsLoadingInventory = true;
        InventoryErrorMessage = "";
        try
        {
            var response = await InventoryService.GetBranchInventoryAsync(branchId);
            if (response.IsSuccess && response.Data != null)
            {
                InventoryItems = response.Data.ToList();
            }
            else
            {
                InventoryErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            InventoryErrorMessage = "Error loading inventory: " + ex.Message;
        }
        finally
        {
            IsLoadingInventory = false;
        }
    }
}
