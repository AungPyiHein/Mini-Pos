@page "/branches"
@layout MainLayout
@using POS.Frontend.Models.Merchants
@inject POS.Frontend.Services.Merchants.IBranchService BranchService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Branches</h2>
            <p class="page-subtitle">Manage store locations</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Branch
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @ErrorMessage
        </div>
    }
    else
    {
        <div class="card">
            <div class="overflow-x-auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Branch Name</th>
                            <th>Location</th>
                            <th>Active Users</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!BranchList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-10 text-muted italic">No branches found</td>
                            </tr>
                        }
                        @foreach (var b in BranchList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-accent">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                                        </div>
                                        <span class="font-medium text-gray-800">@b.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted">@b.Address</td>
                                <td class="text-muted">@b.ActiveUsersCount</td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500">Archive</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    private List<BranchResponseDto> BranchList = new();
    private bool IsLoading = true;
    private string ErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
    }

    private async Task LoadBranches()
    {
        IsLoading = true;
        ErrorMessage = "";
        try
        {
            var response = await BranchService.GetAllBranchesAsync();
            if (response.IsSuccess && response.Data != null)
            {
                BranchList = response.Data.ToList();
            }
            else
            {
                ErrorMessage = response.Message;
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }
}
