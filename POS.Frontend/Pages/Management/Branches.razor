@page "/branches"
@layout MainLayout
@using POS.Frontend.Models.Merchants
@inject POS.Frontend.Services.Merchants.IBranchService BranchService
@inject POS.Frontend.Services.Merchants.IMerchantService MerchantService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Branches</h2>
            <p class="page-subtitle">Manage store locations</p>
        </div>
        <button class="btn-primary" @onclick="ShowAddModal">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Branch
        </button>
    </div>

    @if (IsLoading)
    {
        <div class="flex justify-center py-20">
            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-accent"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="p-4 bg-red-50 border border-red-200 rounded-xl text-red-700 text-sm">
            @ErrorMessage
        </div>
    }
    else
    {
        <div class="card">
            <div class="overflow-x-auto">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Branch Name</th>
                            <th>Location</th>
                            <th>Active Users</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!BranchList.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-10 text-muted italic">No branches found</td>
                            </tr>
                        }
                        @foreach (var b in BranchList)
                        {
                            <tr>
                                <td>
                                    <div class="flex items-center gap-2">
                                        <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-accent">
                                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                                        </div>
                                        <span class="font-medium text-gray-800 dark:text-gray-200">@b.Name</span>
                                    </div>
                                </td>
                                <td class="text-muted">@b.Address</td>
                                <td class="text-muted">@b.ActiveUsersCount</td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="btn-ghost py-1 px-2 text-xs" @onclick="() => ShowEditModal(b)">Edit</button>
                                        <button class="btn-ghost py-1 px-2 text-xs text-red-500" @onclick="() => DeleteBranch(b.Id)">Archive</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@if (ShowModal)
{
    <div class="fixed inset-0 bg-black/50 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white dark:bg-surface rounded-2xl shadow-xl w-full max-w-md overflow-hidden">
            <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100">@(IsEditMode ? "Edit Branch" : "Add New Branch")</h3>
                <button @onclick="CloseModal" class="text-gray-400 hover:text-gray-600 dark:text-gray-400 transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <div class="p-6 space-y-4">
                @if (!IsEditMode)
                {
                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Select Merchant</label>
                        <select class="form-input w-full" @bind="CurrentBranch.MerchantId">
                            <option value="">-- Choose Merchant --</option>
                            @foreach (var m in MerchantList)
                            {
                                <option value="@m.Id">@m.Name</option>
                            }
                        </select>
                    </div>
                }
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Branch Name</label>
                    <input type="text" class="form-input w-full" @bind="CurrentBranch.Name" placeholder="Branch Name" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Address</label>
                    <input type="text" class="form-input w-full" @bind="CurrentBranch.Address" placeholder="Physical Address" />
                </div>
            </div>
            <div class="px-6 py-4 bg-gray-50 dark:bg-surface flex justify-end gap-3">
                <button @onclick="CloseModal" class="btn-ghost">Cancel</button>
                <button @onclick="SaveBranch" class="btn-primary" disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin mr-2"></div>
                    }
                    @(IsEditMode ? "Save Changes" : "Create Branch")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<BranchResponseDto> BranchList = new();
    private List<MerchantResponseDto> MerchantList = new();
    private CreateBranchRequest CurrentBranch = new();
    private Guid? EditingId;
    private bool IsLoading = true;
    private bool IsSaving = false;
    private bool ShowModal = false;
    private bool IsEditMode = false;
    private string ErrorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadBranches();
    }

    private async Task LoadBranches()
    {
        IsLoading = true;
        ErrorMessage = "";
        try
        {
            var response = await BranchService.GetAllBranchesAsync();
            if (response.IsSuccess && response.Data != null)
            {
                BranchList = response.Data.ToList();
            }
            else
            {
                ErrorMessage = response.Message;
            }

            // Also load merchants for the add modal
            var merchantsResponse = await MerchantService.GetAllMerchantsAsync();
            if (merchantsResponse.IsSuccess && merchantsResponse.Data != null)
            {
                MerchantList = merchantsResponse.Data.ToList();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void ShowAddModal()
    {
        IsEditMode = false;
        CurrentBranch = new CreateBranchRequest();
        ShowModal = true;
    }

    private void ShowEditModal(BranchResponseDto branch)
    {
        IsEditMode = true;
        EditingId = branch.Id;
        CurrentBranch = new CreateBranchRequest
        {
            Name = branch.Name,
            Address = branch.Address ?? "",
            MerchantId = Guid.Empty // MerchantId is not editable in this simple view
        };
        ShowModal = true;
    }

    private void CloseModal()
    {
        ShowModal = false;
    }

    private async Task SaveBranch()
    {
        if (string.IsNullOrWhiteSpace(CurrentBranch.Name)) return;
        if (!IsEditMode && CurrentBranch.MerchantId == Guid.Empty) return;

        IsSaving = true;
        try
        {
            bool success;
            if (IsEditMode && EditingId.HasValue)
            {
                var request = new UpdateBranchRequest
                {
                    Id = EditingId.Value,
                    Name = CurrentBranch.Name,
                    Address = CurrentBranch.Address
                };
                var response = await BranchService.UpdateBranchAsync(EditingId.Value, request);
                success = response.IsSuccess;
            }
            else
            {
                var response = await BranchService.CreateBranchAsync(CurrentBranch);
                success = response.IsSuccess;
            }

            if (success)
            {
                ShowModal = false;
                await LoadBranches();
            }
        }
        finally
        {
            IsSaving = false;
        }
    }

    private async Task DeleteBranch(Guid id)
    {
        var response = await BranchService.DeleteBranchAsync(id);
        if (response.IsSuccess)
        {
            await LoadBranches();
        }
    }
}
