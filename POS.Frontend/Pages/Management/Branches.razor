@page "/branches"
@layout MainLayout

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Branches</h2>
            <p class="page-subtitle">Manage store locations</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Branch
        </button>
    </div>

    <div class="card">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Branch Name</th>
                        <th>Merchant</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in BranchList)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-lg bg-indigo-50 flex items-center justify-center text-accent">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
                                    </div>
                                    <span class="font-medium text-gray-800">@b.Name</span>
                                </div>
                            </td>
                            <td><span class="badge badge-info">@b.Merchant</span></td>
                            <td class="text-muted">@b.Location</td>
                            <td>
                                @if (b.Active)
                                { <span class="badge badge-success">Active</span> }
                                else
                                { <span class="badge badge-warning">Archived</span> }
                            </td>
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                    @if (b.Active)
                                    { <button class="btn-ghost py-1 px-2 text-xs text-red-500">Archive</button> }
                                    else
                                    { <button class="btn-ghost py-1 px-2 text-xs text-emerald-600">Restore</button> }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    record BranchRow(string Name, string Merchant, string Location, bool Active);

    List<BranchRow> BranchList = new()
    {
        new("Downtown Express", "Coffee Corp", "123 Main St, New York", true),
        new("Uptown Central",   "Coffee Corp", "456 Lexington Ave, New York", true),
        new("Brooklyn Cafe",    "Coffee Corp", "789 Bedford Ave, Brooklyn", true),
        new("Westside Market",  "Foodies LLC", "321 West End, New York", true),
        new("Closed Location",  "Foodies LLC", "N/A", false),
    };
}
