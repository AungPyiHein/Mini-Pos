@page "/customers"
@layout MainLayout

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Customers</h2>
            <p class="page-subtitle">Manage your customer list</p>
        </div>
        <button class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            Add Customer
        </button>
    </div>

    <div class="card">
        <div class="card-header">
            <input type="text" placeholder="Search customers…" class="form-input max-w-xs" />
            <span class="text-xs text-muted">@CustomerList.Count total</span>
        </div>
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Phone</th>
                        <th>Email</th>
                        <th>Total Orders</th>
                        <th>Total Spent</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in CustomerList)
                    {
                        <tr>
                            <td>
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-full bg-accent/10 flex items-center justify-center shrink-0">
                                        <span class="text-accent text-xs font-semibold">@c.Name[0]</span>
                                    </div>
                                    <span class="font-medium text-gray-800">@c.Name</span>
                                </div>
                            </td>
                            <td class="text-muted">@c.Phone</td>
                            <td class="text-muted">@c.Email</td>
                            <td>@c.Orders</td>
                            <td class="font-semibold">$@c.Spent</td>
                            <td>
                                <div class="flex gap-1">
                                    <button class="btn-ghost py-1 px-2 text-xs">Edit</button>
                                    <button class="btn-ghost py-1 px-2 text-xs text-red-500">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    record CustomerRow(string Name, string Phone, string Email, int Orders, string Spent);

    List<CustomerRow> CustomerList = new()
    {
        new("Alice Johnson",  "+1 555-0101", "alice@email.com",   18, "1,240.00"),
        new("Bob Smith",      "+1 555-0102", "bob@email.com",      7,   "320.50"),
        new("Carol White",    "+1 555-0103", "carol@email.com",   25, "3,180.00"),
        new("David Lee",      "+1 555-0104", "david@email.com",    3,   "145.00"),
        new("Eve Martinez",   "+1 555-0105", "eve@email.com",     12,   "890.75"),
        new("Frank Wilson",   "+1 555-0106", "frank@email.com",    9,   "580.00"),
        new("Grace Kim",      "+1 555-0107", "grace@email.com",   31, "4,920.00"),
        new("Henry Brown",    "+1 555-0108", "henry@email.com",    2,    "45.50"),
    };
}
