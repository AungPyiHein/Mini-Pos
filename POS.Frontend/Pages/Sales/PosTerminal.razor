@page "/sales/terminal"
@layout MainLayout

<div class="flex gap-4 h-[calc(100vh-7.5rem)]">

    <!-- LEFT: Product browser -->
    <div class="flex flex-col flex-1 gap-4 min-w-0">

        <!-- Search + category filter -->
        <div class="flex gap-3">
            <div class="relative flex-1">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                <input type="text" placeholder="Search products…" class="form-input pl-9" @bind="SearchQuery" />
            </div>
        </div>

        <!-- Category chips -->
        <div class="flex gap-2 flex-wrap">
            @foreach (var cat in Categories)
            {
                <button class="px-3 py-1.5 rounded-full text-xs font-medium transition-all @(SelectedCategory == cat ? "bg-accent text-white" : "bg-white border border-border text-muted hover:border-accent hover:text-accent")"
                        @onclick="() => SelectedCategory = cat">
                    @cat
                </button>
            }
        </div>

        <!-- Product grid -->
        <div class="flex-1 overflow-y-auto">
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
                @foreach (var p in FilteredProducts)
                {
                    <button class="bg-white rounded-xl border border-border p-3 text-left hover:border-accent hover:shadow-card-hover transition-all group"
                            @onclick="() => AddToCart(p)">
                        <div class="w-full h-16 rounded-lg bg-gray-50 flex items-center justify-center text-2xl mb-2 group-hover:bg-indigo-50 transition-colors">
                            @p.Icon
                        </div>
                        <p class="text-xs font-semibold text-gray-800 truncate">@p.Name</p>
                        <p class="text-xs text-muted">@p.Category</p>
                        <p class="text-sm font-bold text-accent mt-1">$@p.Price.ToString("0.00")</p>
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- RIGHT: Cart / Receipt -->
    <div class="w-80 shrink-0 flex flex-col bg-white rounded-2xl border border-border shadow-card overflow-hidden">

        <!-- Cart header -->
        <div class="px-5 py-4 border-b border-border flex items-center justify-between">
            <p class="font-semibold text-gray-900 text-sm">Current Order</p>
            <button class="text-xs text-red-500 hover:underline" @onclick="ClearCart">Clear</button>
        </div>

        <!-- Cart items -->
        <div class="flex-1 overflow-y-auto divide-y divide-border/60">
            @if (!CartItems.Any())
            {
                <div class="flex flex-col items-center justify-center h-full py-12 text-center">
                    <div class="w-12 h-12 rounded-full bg-gray-50 flex items-center justify-center mb-3">
                        <svg class="w-5 h-5 text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4" /></svg>
                    </div>
                    <p class="text-sm text-muted">Cart is empty</p>
                    <p class="text-xs text-gray-400 mt-1">Tap a product to add it</p>
                </div>
            }
            else
            {
                @foreach (var item in CartItems)
                {
                    <div class="flex items-center gap-3 px-4 py-3">
                        <span class="text-lg">@item.Icon</span>
                        <div class="flex-1 min-w-0">
                            <p class="text-xs font-medium text-gray-800 truncate">@item.Name</p>
                            <p class="text-xs text-accent font-semibold">$@item.Price.ToString("0.00")</p>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <button class="w-5 h-5 rounded-md bg-gray-100 text-gray-600 text-xs font-bold flex items-center justify-center hover:bg-gray-200"
                                    @onclick="() => ChangeQty(item, -1)">−</button>
                            <span class="text-xs font-semibold w-4 text-center">@item.Qty</span>
                            <button class="w-5 h-5 rounded-md bg-accent/10 text-accent text-xs font-bold flex items-center justify-center hover:bg-accent/20"
                                    @onclick="() => ChangeQty(item, 1)">+</button>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Totals -->
        <div class="px-5 py-4 border-t border-border space-y-2">
            <div class="flex justify-between text-xs text-muted">
                <span>Subtotal</span><span>$@Subtotal.ToString("0.00")</span>
            </div>
            <div class="flex justify-between text-xs text-muted">
                <span>Tax (5%)</span><span>$@Tax.ToString("0.00")</span>
            </div>
            <div class="flex justify-between text-sm font-bold text-gray-900 pt-2 border-t border-border">
                <span>Total</span><span>$@Total.ToString("0.00")</span>
            </div>
        </div>

        <!-- Customer select -->
        <div class="px-5 pb-3">
            <select class="form-input text-xs">
                <option value="">— Walk-in Customer —</option>
                <option>Alice Johnson</option>
                <option>Bob Smith</option>
                <option>Carol White</option>
            </select>
        </div>

        <!-- Charge button -->
        <div class="px-5 pb-5">
            <button class="w-full btn-primary justify-center py-3 text-sm font-semibold rounded-xl @(CartItems.Any() ? "" : "opacity-50 cursor-not-allowed")">
                Charge $@Total.ToString("0.00")
            </button>
        </div>

    </div>
</div>

@code {
    string SearchQuery = "";
    string SelectedCategory = "All";

    List<string> Categories = new() { "All", "Beverages", "Food", "Bakery", "Snacks" };

    record Product(string Name, string Icon, string Category, decimal Price);
    record CartItem(string Name, string Icon, decimal Price) { public int Qty { get; set; } = 1; }

    List<Product> Products = new()
    {
        new("Espresso",      "☕", "Beverages", 3.50m),
        new("Latte",         "🥛", "Beverages", 4.50m),
        new("Orange Juice",  "🧃", "Beverages", 3.00m),
        new("Green Tea",     "🍵", "Beverages", 2.50m),
        new("Margherita",    "🍕", "Food",      16.00m),
        new("Caesar Salad",  "🥗", "Food",      12.00m),
        new("Cheeseburger",  "🍔", "Food",      11.50m),
        new("Fish & Chips",  "🐟", "Food",      14.00m),
        new("Croissant",     "🥐", "Bakery",     3.50m),
        new("Choc. Cake",    "🍰", "Bakery",     5.50m),
        new("Muffin",        "🧁", "Bakery",     2.75m),
        new("Chips",         "🍟", "Snacks",     2.00m),
        new("Popcorn",       "🍿", "Snacks",     3.00m),
        new("Nuts Mix",      "🥜", "Snacks",     4.00m),
    };

    List<CartItem> CartItems = new();

    IEnumerable<Product> FilteredProducts => Products.Where(p =>
        (SelectedCategory == "All" || p.Category == SelectedCategory) &&
        (string.IsNullOrWhiteSpace(SearchQuery) || p.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)));

    decimal Subtotal => CartItems.Sum(i => i.Price * i.Qty);
    decimal Tax => Math.Round(Subtotal * 0.05m, 2);
    decimal Total => Subtotal + Tax;

    void AddToCart(Product p)
    {
        var existing = CartItems.FirstOrDefault(c => c.Name == p.Name);
        if (existing != null) existing.Qty++;
        else CartItems.Add(new CartItem(p.Name, p.Icon, p.Price));
    }

    void ChangeQty(CartItem item, int delta)
    {
        item.Qty += delta;
        if (item.Qty <= 0) CartItems.Remove(item);
    }

    void ClearCart() => CartItems.Clear();
}
