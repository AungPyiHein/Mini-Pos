@page "/sales"
@layout MainLayout
@using POS.Frontend.Services.Sales
@using POS.Frontend.Models.Sales
@using POS.Shared.Models
@inject ISaleService SaleService

<div class="space-y-5">

    <div class="page-header">
        <div>
            <h2 class="page-title">Sales History</h2>
            <p class="page-subtitle">All recorded transactions</p>
        </div>
        <a href="sales/terminal" class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
            New Sale
        </a>
    </div>

    <!-- Filters -->
    <div class="card">
        <div class="card-body">
            <div class="flex flex-wrap gap-3 items-center">
                <input type="text" placeholder="Search invoice or customer…" class="form-input max-w-xs" />
                <input type="date" class="form-input w-40" />
                <input type="date" class="form-input w-40" />
                <button class="btn-primary">Filter</button>
                <button class="btn-secondary">Clear</button>
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="card">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Invoice</th>
                        <th>Customer</th>
                        <th>Branch</th>
                        <th>Items</th>
                        <th>Date & Time</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody class="relative">
                    @if (_isLoading)
                    {
                        <tr>
                            <td colspan="8" class="text-center py-8">
                                <div class="flex flex-col items-center justify-center text-muted">
                                    <svg class="animate-spin h-8 w-8 text-primary mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <p>Loading sales history...</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <tr>
                            <td colspan="8" class="text-center py-8 text-red-500">
                                <p>@_errorMessage</p>
                                <button class="btn-secondary mt-4" @onclick="LoadSales">Try Again</button>
                            </td>
                        </tr>
                    }
                    else if (!Sales.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-8 text-muted">
                                <p>No transactions found.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var s in Sales)
                        {
                            <tr>
                                <td><span class="font-medium text-accent" title="@s.Id">#@s.Id.ToString().Substring(0, 8)</span></td>
                                <td>@s.CustomerName</td>
                                <td><span class="badge badge-info">Main Branch</span></td>
                                <td>@s.Items.Sum(i => i.Quantity)</td>
                                <td class="text-muted text-xs">@s.OrderDate.ToString("dd MMM yyyy, HH:mm")</td>
                                <td class="font-semibold">$@s.TotalAmount.ToString("0.00")</td>
                                <td><span class="badge badge-success">@s.Status</span></td>
                                <td>
                                    <a href="sales/@s.Id" class="btn-ghost py-1 px-2 text-xs">View</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div class="px-5 py-3 border-t border-border flex items-center justify-between">
            <p class="text-xs text-muted">Showing results</p>
            <div class="flex gap-1">
                <button class="btn-secondary py-1 px-3 text-xs" disabled>← Prev</button>
                <button class="btn-primary py-1 px-3 text-xs" disabled>Next →</button>
            </div>
        </div>
    </div>

</div>

@code {
    private List<OrderResponseDto> Sales = new();
    private bool _isLoading = true;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadSales();
    }

    private async Task LoadSales()
    {
        _isLoading = true;
        _errorMessage = null;

        var response = await SaleService.GetAllOrdersAsync();
        if (response?.Data != null)
        {
            Sales = response.Data.ToList();
        }
        else
        {
            _errorMessage = response?.Message ?? "Unknown error occurred";
        }
        _isLoading = false;
    }
}
